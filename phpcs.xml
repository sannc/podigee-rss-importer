<?xml version="1.0"?>
<ruleset name="Podigee RSS Importer">
	<description>PHPCS rules for the Podigee RSS Importer plugin.</description>

	<!-- What to scan -->
	<file>podigee-rss-importer.php</file>
	<file>includes/</file>
	<file>admin/</file>
	<file>uninstall.php</file>

	<!-- Excludes -->
	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>public/assets/*</exclude-pattern>

	<!-- Arguments -->
	<arg value="sp"/>
	<arg name="extensions" value="php"/>
	<arg name="colors"/>

	<!-- WordPress Coding Standards -->
	<rule ref="WordPress">
		<!-- Allow short array syntax -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>

		<!-- Class file naming: our convention omits the "podigee-" prefix -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>

		<!-- Yoda conditions: not our style -->
		<exclude name="WordPress.PHP.YodaConditions"/>

		<!-- Short ternaries: valid modern PHP -->
		<exclude name="Universal.Operators.DisallowShortTernary"/>

		<!-- DOM API properties are camelCase by definition -->
		<exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>

		<!-- Array alignment: stylistic, not enforced -->
		<exclude name="WordPress.Arrays.MultipleStatementAlignment"/>
		<exclude name="Generic.Formatting.MultipleStatementAlignment"/>

		<!-- @package tag not needed for a plugin -->
		<exclude name="Squiz.Commenting.FileComment.MissingPackageTag"/>

		<!-- Doc comments: not enforced for a small plugin -->
		<exclude name="Squiz.Commenting.ClassComment.Missing"/>
		<exclude name="Squiz.Commenting.FunctionComment.Missing"/>
		<exclude name="Squiz.Commenting.FunctionComment.MissingParamTag"/>
		<exclude name="Squiz.Commenting.FunctionComment.WrongStyle"/>
		<exclude name="Squiz.Commenting.VariableComment.Missing"/>

		<!-- Pre-increment preference: stylistic -->
		<exclude name="WordPress.CodeAnalysis.AssignmentInTernaryCondition"/>
	</rule>

	<!-- Allow post-increment (WordPress prefers pre-increment but both are fine) -->
	<rule ref="Universal.Operators.DisallowStandalonePostIncrementDecrement">
		<severity>0</severity>
	</rule>

	<!-- Text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="podigee-rss-importer"/>
			</property>
		</properties>
	</rule>

	<!-- Minimum supported versions -->
	<config name="minimum_supported_wp_version" value="6.0"/>
	<config name="testVersion" value="8.0-"/>
</ruleset>
