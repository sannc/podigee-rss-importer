#. Plugin URI of the plugin
#: podigee-rss-importer.php
msgid "https://github.com/sannc/podigee-rss-importer"
msgstr "https://github.com/sannc/podigee-rss-importer"

#. Description of the plugin
#: podigee-rss-importer.php
msgid "Importiert Podigee-Podcast-RSS-Feeds als WordPress-Posts. Unterstützt mehrere Feeds, konfigurierbar pro Feed."
msgstr "Imports Podigee podcast RSS feeds as WordPress posts. Supports multiple feeds, configurable per feed."

